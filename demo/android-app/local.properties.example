# Convert Android SDK Demo App — local.properties example
#
# Copy this file to `local.properties` and uncomment the lines you want
# to override. Every entry below is OPTIONAL — when absent, the demo
# falls back to the hardcoded literals documented next to each key, so
# `./gradlew :app:assembleDebug` on a fresh clone succeeds with no
# extra setup. `demo/android-app/.gitignore` keeps `local.properties`
# out of version control so your real SDK key never hits git.

# ---------------------------------------------------------------------------
# Android SDK path
# ---------------------------------------------------------------------------
# Android Studio normally populates this automatically when you first open
# the project — the line below is here only as a template.
# sdk.dir=/Users/you/Library/Android/sdk

# ---------------------------------------------------------------------------
# Convert SDK key
# ---------------------------------------------------------------------------
# The merchant SDK key the demo initialises `ConvertSDK.Builder.sdkKey(…)`
# with. Default when omitted: `"demo-sdk-key"` (the demo still launches,
# but the first config fetch fails quietly).
# convertSdkKey=your-staging-sdk-key-here

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
# Deployment environment tag passed to `ConvertSDK.Builder.environment(…)`
# (typically `"staging"` or `"production"`). Default when omitted or blank:
# the builder call is skipped entirely, and the Config screen's
# Environment row renders `(not set)`.
# convertEnvironment=staging

# ---------------------------------------------------------------------------
# Experience key
# ---------------------------------------------------------------------------
# Experience key the Experiences / Offline screens' primary buttons
# target via `ConvertContext.runExperience(…)`. Default when omitted:
# `"test-experience"`.
# convertExperienceKey=your-experience-key

# ---------------------------------------------------------------------------
# Feature key
# ---------------------------------------------------------------------------
# Feature key the Features screen's primary button targets via
# `ConvertContext.runFeature(…)`. Default when omitted: `"test-feature"`.
# convertFeatureKey=your-feature-key

# ---------------------------------------------------------------------------
# Goal key
# ---------------------------------------------------------------------------
# Goal key the Conversions / Offline screens' Buy button tracks via
# `ConvertContext.trackConversion(…)`. Default when omitted:
# `"purchase-goal"`.
# convertGoalKey=your-goal-key
